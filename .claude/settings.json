{
  "permissions": {
    "allow": [
      "Bash(git *)", "Bash(squeue *)", "Bash(sacct *)",
      "Bash(scancel *)", "Bash(sbatch *)", "Bash(cat *)",
      "Bash(grep *)", "Bash(find *)", "Bash(tail *)",
      "Bash(ls *)", "Bash(head *)",
      "Edit", "Write", "Read"
    ],
    "deny": ["Bash(rm *)", "Bash(mv *)"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'REMINDER: Read md_files/WORKFLOW.md and the relevant .claude/skills/{stage}/SKILL.md before writing any script.'"
          }
        ]
      }
    ]
  }
}
