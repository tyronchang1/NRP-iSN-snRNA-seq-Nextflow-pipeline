params {
    project_root = "/scratch/rmlab/rmlab_shared3/tyron/Rscriptv2/iSN/iSN_claude"  // overridden at runtime by run.sh via --project_root
    r_bin        = "/ref/rmlab/software/spack-1.1.0/opt/spack/linux-x86_64/r-4.5.2-jga4yt5sdbzfddqszotqf64bn5a6iu2m/bin"
    r_libs       = "/ref/rmlab/software/tyron/R-libs"
    seed         = 123
    gene_sets    = ""
    track        = "both"

    samples = [
        "NR00_Day13_1",
        "NR00_Day13_1_dup",
        "NR00_Day13_2",
        "NR00_Day13_2_dup",
        "NR00_Day7_1",
        "NR00_Day7_2",
        "NR00_iPSC_1",
        "NR00_iPSC_2"
    ]

    // Stage 03 QC thresholds — set after inspecting density histogram
    // ncount_min     = null
    // nfeature_min   = null
    // percent_mt_max = null

    // Stage 04 clustering resolution — set after inspecting UMAP plots
    // resolution = null

}

process {
    executor = 'slurm'
    queue    = 'interactive'

    withName: 'SOUPX' {
        cpus   = 4
        memory = '200 GB'
        time   = '2h'
    }
    withName: 'DECONTX' {
        cpus   = 4
        memory = '200 GB'
        time   = '4h'
    }
    withName: 'SCDBLFINDER' {
        cpus   = 4
        memory = '200 GB'
        time   = '2h'
    }
    withName: 'SCDBLFINDER_DECONTX' {
        cpus   = 4
        memory = '200 GB'
        time   = '2h'
    }
    withName: 'CELL_FILTERING_SOUPX|CELL_FILTERING_DECONTX' {
        cpus   = 2
        memory = '200 GB'
        time   = '1h'
    }
    withName: 'CLUSTERING_SOUPX|CLUSTERING_DECONTX' {
        cpus   = 8
        memory = '200 GB'
        time   = '8h'
    }
    withName: 'MERGE_REPORT_SOUPX|MERGE_REPORT_DECONTX' {
        cpus   = 4
        memory = '100 GB'
        time   = '2h'
    }
}

env {
    RSTUDIO_PANDOC = "/home/tyron/miniconda3/bin"
}

trace {
    overwrite = true
}

report {
    overwrite = true
}

timeline {
    overwrite = true
}

notification {
    enabled = true
    to      = 'tyron@wustl.edu'
}
